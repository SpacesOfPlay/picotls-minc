private {
i32 buffer_encrypt_record(ptls_buffer_t* buf, u64 rec_start, st_ptls_traffic_protection_t* enc) {
    u64 bodylen = 0;
    u8* tmpbuf = null;
    bool _keep = false;
    defer {
        if !_keep {
            if tmpbuf != null {
                ptls_clear_memory(tmpbuf, bodylen);
                free(tmpbuf);
            }
        }
    }
    bodylen = buf.off - rec_start - 5;
    u8 type = buf.base[rec_start];
    i32 ret;
    if !enc.tls12 && bodylen <= 16384 {
        u64 overhead = 1 + enc.aead.algo.tag_size;
        ret = ptls_buffer_reserve_aligned(buf, overhead, enc.aead.algo.align_bits);
        if ret != 0 {
            _keep = true;
            _keep = true;
            return ret;
        }
        u64 encrypted_len = aead_encrypt(enc, buf.base + rec_start + 5, buf.base + rec_start + 5, bodylen, type);
        assert(encrypted_len == bodylen + overhead);
        buf.off += overhead;
        buf.base[rec_start] = 23;
        buf.base[rec_start + 3] = cast(u8, encrypted_len >> 8 & 255);
        buf.base[rec_start + 4] = cast(u8, encrypted_len & 255);
        _keep = true;
        return 0;
    }
    tmpbuf = malloc(bodylen);
    if tmpbuf == null {
        ret = 512 + 1;
        return ret;
    }
    memcpy(tmpbuf, buf.base + rec_start + 5, bodylen);
    ptls_clear_memory(buf.base + rec_start, bodylen + 5);
    buf.off = rec_start;
    ret = buffer_push_encrypted_records(buf, type, tmpbuf, bodylen, enc);
}
}
private {
i32 begin_record_message(ptls_message_emitter_t* _self) {
    var self = cast(st_ptls_record_message_emitter_t*, _self);
    i32 ret;
    self.rec_start = self.super.buf.off;
    while true {
        u8[5] __compound_lit_11 = {22, 3, 3, 0, 0};
        u8[5] __compound_lit_12 = {22, 3, 3, 0, 0};
        ret = ptls_buffer__do_pushv(self.super.buf, __compound_lit_11, cast(u64, sizeof(__compound_lit_12)));
        if ret != 0 {
            return ret;
        }
        if !(0 != 0) { break; }
    }
    ret = 0;
    return ret;
}
}
private {
i32 commit_record_message(ptls_message_emitter_t* _self) {
    var self = cast(st_ptls_record_message_emitter_t*, _self);
    i32 ret;
    if self.super.enc.aead != null {
        ret = buffer_encrypt_record(self.super.buf, self.rec_start, self.super.enc);
    } else {
        u64 sz = self.super.buf.off - self.rec_start - 5;
        assert(sz <= 16384);
        self.super.buf.base[self.rec_start + 3] = cast(u8, sz >> 8);
        self.super.buf.base[self.rec_start + 4] = cast(u8, sz);
        ret = 0;
    }
    return ret;
}
}
i32 ptls_decode8(u8* value, u8** src, u8* end) {
    if *src == end {
        return 50;
    }
    *value = *(*src)++;
    return 0;
}
i32 ptls_decode16(u16* value, u8** src, u8* end) {
    if cast(i64, end - *src) < 2 {
        return 50;
    }
    *value = ntoh16(*src);
    *src += 2;
    return 0;
}
i32 ptls_decode24(u32* value, u8** src, u8* end) {
    if cast(i64, end - *src) < 3 {
        return 50;
    }
    *value = cast(u32, (*src)[0]) << 16 | cast(u32, (*src)[1]) << 8 | (*src)[2];
    *src += 3;
    return 0;
}
i32 ptls_decode32(u32* value, u8** src, u8* end) {
    if cast(i64, end - *src) < 4 {
        return 50;
    }
    *value = ntoh32(*src);
    *src += 4;
    return 0;
}
i32 ptls_decode64(u64* value, u8** src, u8* end) {
    if cast(i64, end - *src) < 8 {
        return 50;
    }
    *value = ntoh64(*src);
    *src += 8;
    return 0;
}
u64 ptls_decode_quicint(u8** src, u8* end) {
    if *src == end {
        return UINT64_MAX;
    }
    u8 b = *(*src)++;
    if b <= 63 {
        return b;
    }
    u64 v = b & 63;
    var bytes_left = cast(u32, (1 << (cast(i32, b) >> 6)) - 1);
    if cast(u64, cast(i64, end - *src)) < bytes_left {
        return UINT64_MAX;
    }
    while true {
        v = v << 8 | *(*src)++;
        if !(--bytes_left != 0) { break; }
    }
    return v;
}
private {
void log_secret(ptls_t* tls, u8* type, ptls_iovec_t secret) {
    u8[129] hexbuf;
        while true {
        u32 active = ptls_log_point_maybe_active(&log_secret__logpoint);
        if active == 0 {
            break;
        }
        ptls_t* _tls = tls;
        ptls_log_conn_state_t* conn_state = ptls_get_log_state(_tls);
        active &= ptls_log_conn_maybe_active(conn_state, ptls_log_getsni_ptls(_tls));
        if active == 0 {
            break;
        }
                if !(0 != 0) { break; }
    }
    if tls.ctx.log_event != null {
        tls.ctx.log_event.cb(tls.ctx.log_event, tls, type, "%s", ptls_hexdump(hexbuf, secret.base, secret.len));
    }
}
}
/**
 * This function preserves the flags and  modes (e.g., `offered`, `accepted`, `cipher`), they can be used afterwards.
 */
private {
void clear_ech(st_ptls_ech_t* ech, i32 is_server) {
    if ech.aead != null {
        ptls_aead_free(ech.aead);
        ech.aead = null;
    }
    ptls_clear_memory(ech.inner_client_random, 32);
    if is_server == 0 {
        free(ech.client.enc.base);
        ech.client.enc = ptls_iovec_init(null, 0);
        if ech.client.public_name != null {
            free(ech.client.public_name);
            ech.client.public_name = null;
        }
        free(ech.client.first_ech.base);
        ech.client.first_ech = ptls_iovec_init(null, 0);
    }
}
