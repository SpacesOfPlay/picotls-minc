    if epoch == 1 && self.super.buf.base[self.start_off] == 1 {
        epoch = 0;
    }
    for ++epoch; epoch < 5; ++epoch {
        assert(self.epoch_offsets[epoch] == self.start_off);
        self.epoch_offsets[epoch] = self.super.buf.off;
    }
