ptls_t* ptls_client_new(ptls_context_t* ctx) {
    ptls_t* tls = new_instance(ctx, 0);
    tls.state = PTLS_STATE_CLIENT_HANDSHAKE_START;
    tls.ctx.random_bytes(tls.client_random, sizeof(tls.client_random));
