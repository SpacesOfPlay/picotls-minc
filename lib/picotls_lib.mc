private {
i32 client_setup_ech(st_ptls_ech_t* ech, st_decoded_ech_config_t* decoded, fn(void*, u64): void random_bytes) {
    i32 ret = 0;
    defer {
        if ret != 0 {
            clear_ech(ech, 0);
        }
    }
    ptls_buffer_t infobuf;
    u8[256] infobuf_smallbuf;
    ptls_buffer_init(&infobuf, infobuf_smallbuf, cast(u64, sizeof(infobuf_smallbuf)));
    while true {
        ret = ptls_buffer__do_pushv(&infobuf, ech_info_prefix, cast(u64, sizeof(ech_info_prefix)));
        if ret != 0 {
            return ret;
        }
        if !(0 != 0) { break; }
    }
    while true {
        ret = ptls_buffer__do_pushv(&infobuf, decoded.bytes.base, decoded.bytes.len);
        if ret != 0 {
            return ret;
        }
        if !(0 != 0) { break; }
    }
    ret = ptls_hpke_setup_base_s(decoded.kem, decoded.cipher, &ech.client.enc, &ech.aead, decoded.public_key, ptls_iovec_init(infobuf.base, infobuf.off));
    if ret != 0 {
        return ret;
    }
    ech.config_id = decoded.id;
    ech.kem = decoded.kem;
    ech.cipher = decoded.cipher;
    random_bytes(ech.inner_client_random, 32);
    ech.client.max_name_length = decoded.max_name_length;
    ech.client.public_name = duplicate_as_str(decoded.public_name.base, decoded.public_name.len);
    if ech.client.public_name == null {
        ret = 512 + 1;
        return ret;
    }
    return ret;
}
}
private {
void client_setup_ech_grease(st_ptls_ech_t* ech, fn(void*, u64): void random_bytes, ptls_hpke_kem_t** kems, ptls_hpke_cipher_suite_t** ciphers, u8* sni_name) {
    u8[32] random_secret;
    for u64 i = 0; kems[i] != null; ++i {
        if kems[i].id == 32 {
            ech.kem = kems[i];
            break;
        }
    }
    for u64 i = 0; ciphers[i] != null; ++i {
        if ciphers[i].id.kdf == 1 && ciphers[i].id.aead == 1 {
            ech.cipher = ciphers[i];
            break;
        }
    }
    if ech.kem == null || ech.cipher == null {
        clear_ech(ech, 0);
        return;
    }
    random_bytes(random_secret, sizeof(random_secret));
    ech.aead = ptls_aead_new_direct(ech.cipher.aead, 1, random_secret, random_secret + 16);
    ech.client.enc.base = malloc(client_setup_ech_grease__x25519_key_size);
    if ech.client.enc.base == null {
        clear_ech(ech, 0);
        return;
    }
    ech.client.enc.len = client_setup_ech_grease__x25519_key_size;
    random_bytes(ech.client.enc.base, ech.client.enc.len);
    random_bytes(&ech.config_id, sizeof(ech.config_id));
    ech.client.max_name_length = 64;
    ech.client.public_name = duplicate_as_str(sni_name, strlen(sni_name));
    if ech.client.public_name == null {
        clear_ech(ech, 0);
        return;
    }
    return;
}
}
private {
i32 ech_calc_confirmation(ptls_key_schedule_t* sched, void* dst, u8* inner_random, u8* label, ptls_iovec_t message) {
    ptls_hash_context_t* hash = null;
    u8[64] secret;
    u8[64] transcript_hash;
    defer {
        ptls_clear_memory(secret, sizeof(secret));
        ptls_clear_memory(transcript_hash, sizeof(transcript_hash));
        if hash != null {
            hash.final(hash, null, PTLS_HASH_FINAL_MODE_FREE);
        }
    }
    hash = null;
    i32 ret;
    hash = (*(&sched.hashes[0] + 0)).ctx.clone_((*(&sched.hashes[0] + 0)).ctx);
    if hash == null {
        ret = 512 + 1;
        return ret;
    }
    hash.update(hash, message.base, message.len);
    hash.final(hash, transcript_hash, PTLS_HASH_FINAL_MODE_FREE);
    hash = null;
    ret = ptls_hkdf_extract((*(&sched.hashes[0] + 0)).algo, secret, ptls_iovec_init(null, 0), ptls_iovec_init(inner_random, 32));
    if ret != 0 {
        return ret;
    }
    ret = ptls_hkdf_expand_label((*(&sched.hashes[0] + 0)).algo, dst, 8, ptls_iovec_init(secret, (*(&sched.hashes[0] + 0)).algo.digest_size), label, ptls_iovec_init(transcript_hash, (*(&sched.hashes[0] + 0)).algo.digest_size), null);
    if ret != 0 {
        return ret;
    }
    return ret;
}
}
private {
void key_schedule_free(ptls_key_schedule_t* sched) {
    u64 i;
    ptls_clear_memory(sched.secret, sizeof(sched.secret));
    for i = 0; i != sched.num_hashes; ++i {
        (*(&sched.hashes[0] + i)).ctx.final((*(&sched.hashes[0] + i)).ctx, null, PTLS_HASH_FINAL_MODE_FREE);
        if (*(&sched.hashes[0] + i)).ctx_outer != null {
            (*(&sched.hashes[0] + i)).ctx_outer.final((*(&sched.hashes[0] + i)).ctx_outer, null, PTLS_HASH_FINAL_MODE_FREE);
        }
    }
    free(sched);
}
}
private {
ptls_key_schedule_t* key_schedule_new(ptls_cipher_suite_t* preferred, ptls_cipher_suite_t** offered, i32 use_outer) {
    ptls_key_schedule_t* sched;
    {
        u64 num_hashes = 0;
        while true {
            ptls_cipher_suite_t* cs;
            cs = preferred;
            if cs != null {
                {
                    ++num_hashes;
                }
            }
            if offered != null {
                u64 i;
                u64 j;
                for i = 0; true; ++i {
                    cs = offered[i];
                    if cs != null == 0 {
                        break;
                    }
                    if preferred == null || cs.hash != preferred.hash {
                        for j = 0; j != i; ++j {
                            if cs.hash == offered[j].hash {
                                break;
                            }
                        }
                        if j == i {
                            {
                                ++num_hashes;
                            }
                        }
                    }
                }
            }
            if !(0 != 0) { break; }
        }
        sched = malloc(cast(u64, &cast(ptls_key_schedule_t*, 0).hashes) + cast(u64, sizeof(*(&sched.hashes[0] + 0))) * num_hashes);
        if sched == null {
            return null;
        }
        *sched = ptls_key_schedule_t{};
    }
    while true {
        ptls_cipher_suite_t* cs;
        cs = preferred;
        if cs != null {
            {
                (*(&sched.hashes[0] + sched.num_hashes)).algo = cs.hash;
                (*(&*(&sched.hashes[0] + 0) + sched.num_hashes)).ctx = cs.hash.create();
                if (*(&*(&sched.hashes[0] + 0) + sched.num_hashes)).ctx == null {
                    key_schedule_free(sched);
                    return null;
                }
                if use_outer != 0 {
                    (*(&*(&sched.hashes[0] + 0) + sched.num_hashes)).ctx_outer = cs.hash.create();
                    if (*(&*(&sched.hashes[0] + 0) + sched.num_hashes)).ctx_outer == null {
                        key_schedule_free(sched);
                        return null;
                    }
                } else {
                    (*(&sched.hashes[0] + sched.num_hashes)).ctx_outer = null;
                }
                ++sched.num_hashes;
            }
        }
        if offered != null {
            u64 i;
            u64 j;
            for i = 0; true; ++i {
                cs = offered[i];
                if cs != null == 0 {
                    break;
                }
                if preferred == null || cs.hash != preferred.hash {
                    for j = 0; j != i; ++j {
                        if cs.hash == offered[j].hash {
                            break;
                        }
                    }
                    if j == i {
                        {
                            (*(&sched.hashes[0] + sched.num_hashes)).algo = cs.hash;
                            (*(&*(&sched.hashes[0] + 0) + sched.num_hashes)).ctx = cs.hash.create();
                            if (*(&*(&sched.hashes[0] + 0) + sched.num_hashes)).ctx == null {
                                key_schedule_free(sched);
                                return null;
                            }
                            if use_outer != 0 {
                                (*(&*(&sched.hashes[0] + 0) + sched.num_hashes)).ctx_outer = cs.hash.create();
                                if (*(&*(&sched.hashes[0] + 0) + sched.num_hashes)).ctx_outer == null {
                                    key_schedule_free(sched);
                                    return null;
                                }
                            } else {
                                (*(&sched.hashes[0] + sched.num_hashes)).ctx_outer = null;
                            }
                            ++sched.num_hashes;
                        }
                    }
                }
            }
        }
        if !(0 != 0) { break; }
    }
    return sched;
}
}
private {
i32 key_schedule_extract(ptls_key_schedule_t* sched, ptls_iovec_t ikm) {
    i32 ret;
    if ikm.base == null {
        ikm = ptls_iovec_init(zeroes_of_max_digest_size, (*(&sched.hashes[0] + 0)).algo.digest_size);
    }
    if sched.generation != 0 {
        ret = ptls_hkdf_expand_label((*(&sched.hashes[0] + 0)).algo, sched.secret, (*(&sched.hashes[0] + 0)).algo.digest_size, ptls_iovec_init(sched.secret, (*(&sched.hashes[0] + 0)).algo.digest_size), "derived", ptls_iovec_init((*(&sched.hashes[0] + 0)).algo.empty_digest, (*(&sched.hashes[0] + 0)).algo.digest_size), null);
        if ret != 0 {
            return ret;
        }
    }
    ++sched.generation;
    ret = ptls_hkdf_extract((*(&sched.hashes[0] + 0)).algo, sched.secret, ptls_iovec_init(sched.secret, (*(&sched.hashes[0] + 0)).algo.digest_size), ikm);
        return ret;
}
}
private {
i32 key_schedule_select_cipher(ptls_key_schedule_t* sched, ptls_cipher_suite_t* cs, i32 reset, ptls_iovec_t reset_ikm) {
    u64 found_slot = SIZE_MAX;
    u64 i;
    i32 ret;
    assert(sched.generation == 1);
    for i = 0; i != sched.num_hashes; ++i {
        if (*(&sched.hashes[0] + i)).algo == cs.hash {
            assert(found_slot == SIZE_MAX);
            found_slot = i;
        } else {
            (*(&sched.hashes[0] + i)).ctx.final((*(&sched.hashes[0] + i)).ctx, null, PTLS_HASH_FINAL_MODE_FREE);
            if (*(&sched.hashes[0] + i)).ctx_outer != null {
                (*(&sched.hashes[0] + i)).ctx_outer.final((*(&sched.hashes[0] + i)).ctx_outer, null, PTLS_HASH_FINAL_MODE_FREE);
            }
        }
    }
    if found_slot != 0 {
        *(&sched.hashes[0] + 0) = *(&sched.hashes[0] + found_slot);
        reset = 1;
    }
    sched.num_hashes = 1;
    if reset != 0 {
        --sched.generation;
        memset(sched.secret, 0, cast(u64, sizeof(sched.secret)));
        ret = key_schedule_extract(sched, reset_ikm);
        if ret != 0 {
            return ret;
        }
    }
    ret = 0;
    return ret;
}
}
private {
void key_schedule_select_outer(ptls_key_schedule_t* sched) {
    assert(sched.generation == 1);
    assert(sched.num_hashes == 1);
    assert((*(&sched.hashes[0] + 0)).ctx_outer != null);
    (*(&sched.hashes[0] + 0)).ctx.final((*(&sched.hashes[0] + 0)).ctx, null, PTLS_HASH_FINAL_MODE_FREE);
    (*(&sched.hashes[0] + 0)).ctx = (*(&sched.hashes[0] + 0)).ctx_outer;
    (*(&sched.hashes[0] + 0)).ctx_outer = null;
}
}
void ptls__key_schedule_update_hash(ptls_key_schedule_t* sched, u8* msg, u64 msglen, i32 use_outer) {
    u64 i;
        for i = 0; i != sched.num_hashes; ++i {
        ptls_hash_context_t* ctx = use_outer != 0 ? (*(&sched.hashes[0] + i)).ctx_outer : (*(&sched.hashes[0] + i)).ctx;
        ctx.update(ctx, msg, msglen);
    }
}
private {
void key_schedule_update_ch1hash_prefix(ptls_key_schedule_t* sched) {
    u8[4] prefix = {254, 0, 0, cast(u8, (*(&sched.hashes[0] + 0)).algo.digest_size)};
    ptls__key_schedule_update_hash(sched, prefix, cast(u64, sizeof(prefix)), 0);
}
}
private {
void key_schedule_extract_ch1hash(ptls_key_schedule_t* sched, u8* hash) {
    assert((*(&sched.hashes[0] + 0)).ctx_outer == null);
    (*(&sched.hashes[0] + 0)).ctx.final((*(&sched.hashes[0] + 0)).ctx, hash, PTLS_HASH_FINAL_MODE_RESET);
}
}
private {
void key_schedule_transform_post_ch1hash(ptls_key_schedule_t* sched) {
    u64 digest_size = (*(&sched.hashes[0] + 0)).algo.digest_size;
    ptls_hash_context_t*[3] hashes = {(*(&sched.hashes[0] + 0)).ctx, (*(&sched.hashes[0] + 0)).ctx_outer, null};
    u8[64] ch1hash;
    u8[4] prefix = {254, 0, 0, cast(u8, digest_size)};
    for u64 i = 0; hashes[i] != null; ++i {
        hashes[i].final(hashes[i], ch1hash, PTLS_HASH_FINAL_MODE_RESET);
        hashes[i].update(hashes[i], prefix, sizeof(prefix));
        hashes[i].update(hashes[i], ch1hash, digest_size);
    }
    ptls_clear_memory(ch1hash, sizeof(ch1hash));
}
}
private {
i32 derive_secret_with_hash(ptls_key_schedule_t* sched, void* secret, u8* label, u8* hash) {
    i32 ret = ptls_hkdf_expand_label((*(&sched.hashes[0] + 0)).algo, secret, (*(&sched.hashes[0] + 0)).algo.digest_size, ptls_iovec_init(sched.secret, (*(&sched.hashes[0] + 0)).algo.digest_size), label, ptls_iovec_init(hash, (*(&sched.hashes[0] + 0)).algo.digest_size), null);
        return ret;
}
}
private {
i32 derive_secret(ptls_key_schedule_t* sched, void* secret, u8* label) {
    u8[64] hash_value;
    (*(&sched.hashes[0] + 0)).ctx.final((*(&sched.hashes[0] + 0)).ctx, hash_value, PTLS_HASH_FINAL_MODE_SNAPSHOT);
    i32 ret = derive_secret_with_hash(sched, secret, label, hash_value);
    ptls_clear_memory(hash_value, sizeof(hash_value));
    return ret;
}
}
private {
i32 derive_secret_with_empty_digest(ptls_key_schedule_t* sched, void* secret, u8* label) {
    return derive_secret_with_hash(sched, secret, label, (*(&sched.hashes[0] + 0)).algo.empty_digest);
}
}
private {
i32 derive_exporter_secret(ptls_t* tls, i32 is_early) {
    i32 ret;
    if tls.ctx.use_exporter == 0 {
        return 0;
    }
    u8** slot = is_early != 0 ? &tls.exporter_master_secret.early : &tls.exporter_master_secret.one_rtt;
    assert(*slot == null);
    *slot = malloc((*(&tls.key_schedule.hashes[0] + 0)).algo.digest_size);
    if *slot == null {
        return 512 + 1;
    }
    ret = derive_secret(tls.key_schedule, *slot, is_early != 0 ? "e exp master" : "exp master");
    if ret != 0 {
        return ret;
    }
    log_secret(tls, is_early != 0 ? "EARLY_EXPORTER_SECRET" : "EXPORTER_SECRET", ptls_iovec_init(*slot, (*(&tls.key_schedule.hashes[0] + 0)).algo.digest_size));
    return 0;
}
}
private {
void free_exporter_master_secret(ptls_t* tls, i32 is_early) {
    u8* slot = is_early != 0 ? tls.exporter_master_secret.early : tls.exporter_master_secret.one_rtt;
    if slot == null {
        return;
    }
    assert(tls.key_schedule != null);
    ptls_clear_memory(slot, (*(&tls.key_schedule.hashes[0] + 0)).algo.digest_size);
    free(slot);
}
}
private {
i32 derive_resumption_secret(ptls_key_schedule_t* sched, u8* secret, ptls_iovec_t nonce) {
    i32 ret = 0;
    defer {
        if ret != 0 {
            ptls_clear_memory(secret, (*(&sched.hashes[0] + 0)).algo.digest_size);
        }
    }
    ret = derive_secret(sched, secret, "res master");
    if ret != 0 {
        return ret;
    }
    ret = ptls_hkdf_expand_label((*(&sched.hashes[0] + 0)).algo, secret, (*(&sched.hashes[0] + 0)).algo.digest_size, ptls_iovec_init(secret, (*(&sched.hashes[0] + 0)).algo.digest_size), "resumption", nonce, null);
    if ret != 0 {
        return ret;
    }
    return ret;
}
}
