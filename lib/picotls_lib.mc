private {
i32 buffer_push_encrypted_records(ptls_buffer_t* buf, u8 type, u8* src, u64 len, st_ptls_traffic_protection_t* enc) {
    i32 ret = 0;
    while len != 0 {
        u64 chunk_size = len;
        if chunk_size > 16384 {
            chunk_size = 16384;
        }
        if enc.tls12 != 0 {
            while true {
                while true {
                    u8[3] __compound_lit_7 = {type, 3, 3};
                    u8[3] __compound_lit_8 = {type, 3, 3};
                    ret = ptls_buffer__do_pushv(buf, __compound_lit_7, cast(u64, sizeof(__compound_lit_8)));
                    if ret != 0 {
                        return ret;
                    }
                    if !(0 != 0) { break; }
                }
                while true {
                    u64 capacity = 2;
                    while true {
                        ret = ptls_buffer__do_pushv(buf, cast(u8*, "\\0\\0\\0\\0\\0\\0\\0"), capacity != cast(u64, -1) ? capacity : 1);
                        if ret != 0 {
                            return ret;
                        }
                        if !(0 != 0) { break; }
                    }
                    u64 body_start = buf.off;
                    while true {
                        {
                            ret = ptls_buffer_reserve_aligned(buf, enc.aead.algo.tls12.record_iv_size + chunk_size + enc.aead.algo.tag_size, enc.aead.algo.align_bits);
                            if ret != 0 {
                                return ret;
                            }
                            u64 nonce;
                            if enc.aead.algo.tls12.record_iv_size != 0 {
                                assert(enc.aead.algo.tls12.record_iv_size == 8);
                                nonce = enc.tls12_enc_record_iv++;
                                encode64(buf.base + buf.off, nonce);
                                buf.off += 8;
                            } else {
                                nonce = enc.seq;
                            }
                            u8[13] aad;
                            build_tls12_aad(aad, type, enc.seq, cast(u16, chunk_size));
                            buf.off += ptls_aead_encrypt(enc.aead, buf.base + buf.off, src, chunk_size, nonce, aad, cast(u64, sizeof(aad)));
                            ++enc.seq;
                        }
                        if !(0 != 0) { break; }
                    }
                    u64 body_size = buf.off - body_start;
                    if capacity != cast(u64, -1) {
                        if capacity < cast(u64, sizeof(u64)) && body_size >= cast(u64, 1) << capacity * 8 {
                            ret = 512 + 12;
                            return ret;
                        }
                        for ; capacity != 0; --capacity {
                            buf.base[body_start - capacity] = cast(u8, body_size >> 8 * (capacity - 1));
                        }
                    } else {
                        ret = ptls_buffer__adjust_quic_blocksize(buf, body_size);
                        if ret != 0 {
                            return ret;
                        }
                    }
                    if !(0 != 0) { break; }
                }
                if !(0 != 0) { break; }
            }
        } else {
            while true {
                while true {
                    u8[3] __compound_lit_9 = {23, 3, 3};
                    u8[3] __compound_lit_10 = {23, 3, 3};
                    ret = ptls_buffer__do_pushv(buf, __compound_lit_9, cast(u64, sizeof(__compound_lit_10)));
                    if ret != 0 {
                        return ret;
                    }
                    if !(0 != 0) { break; }
                }
                while true {
                    u64 capacity = 2;
                    while true {
                        ret = ptls_buffer__do_pushv(buf, cast(u8*, "\\0\\0\\0\\0\\0\\0\\0"), capacity != cast(u64, -1) ? capacity : 1);
                        if ret != 0 {
                            return ret;
                        }
                        if !(0 != 0) { break; }
                    }
                    u64 body_start = buf.off;
                    while true {
                        {
                            ret = ptls_buffer_reserve_aligned(buf, chunk_size + enc.aead.algo.tag_size + 1, enc.aead.algo.align_bits);
                            if ret != 0 {
                                return ret;
                            }
                            buf.off += aead_encrypt(enc, buf.base + buf.off, src, chunk_size, type);
                        }
                        if !(0 != 0) { break; }
                    }
                    u64 body_size = buf.off - body_start;
                    if capacity != cast(u64, -1) {
                        if capacity < cast(u64, sizeof(u64)) && body_size >= cast(u64, 1) << capacity * 8 {
                            ret = 512 + 12;
                            return ret;
                        }
                        for ; capacity != 0; --capacity {
                            buf.base[body_start - capacity] = cast(u8, body_size >> 8 * (capacity - 1));
                        }
                    } else {
                        ret = ptls_buffer__adjust_quic_blocksize(buf, body_size);
                        if ret != 0 {
                            return ret;
                        }
                    }
                    if !(0 != 0) { break; }
                }
