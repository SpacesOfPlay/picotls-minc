        b.a[i] += b.a[i + 4] + (cast(u64, cast(u32, b.a[i])) * cast(u64, cast(u32, b.a[i + 4])) << 1);
        b.a[i + 12] ^= b.a[i];
        b.a[i + 12] = mc_rotr64(b.a[i + 12], 16);
        b.a[i + 8] += b.a[i + 12] + (cast(u64, cast(u32, b.a[i + 8])) * cast(u64, cast(u32, b.a[i + 12])) << 1);
