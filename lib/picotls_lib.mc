        v2 += v6 + input[mc_blake2b_compress__sigma[11][5]];
        v14 = mc_rotr64(v14 ^ v2, 16);
        v10 += v14;
        v6 = mc_rotr64(v6 ^ v10, 63);
        v3 += v7 + input[mc_blake2b_compress__sigma[11][6]];
        v15 = mc_rotr64(v15 ^ v3, 32);
        v11 += v15;
        v7 = mc_rotr64(v7 ^ v11, 24);
        v3 += v7 + input[mc_blake2b_compress__sigma[11][7]];
        v15 = mc_rotr64(v15 ^ v3, 16);
        v11 += v15;
        v7 = mc_rotr64(v7 ^ v11, 63);
        v0 += v5 + input[mc_blake2b_compress__sigma[11][8]];
        v15 = mc_rotr64(v15 ^ v0, 32);
        v10 += v15;
        v5 = mc_rotr64(v5 ^ v10, 24);
        v0 += v5 + input[mc_blake2b_compress__sigma[11][9]];
        v15 = mc_rotr64(v15 ^ v0, 16);
        v10 += v15;
        v5 = mc_rotr64(v5 ^ v10, 63);
        v1 += v6 + input[mc_blake2b_compress__sigma[11][10]];
        v12 = mc_rotr64(v12 ^ v1, 32);
        v11 += v12;
        v6 = mc_rotr64(v6 ^ v11, 24);
        v1 += v6 + input[mc_blake2b_compress__sigma[11][11]];
        v12 = mc_rotr64(v12 ^ v1, 16);
        v11 += v12;
        v6 = mc_rotr64(v6 ^ v11, 63);
        v2 += v7 + input[mc_blake2b_compress__sigma[11][12]];
        v13 = mc_rotr64(v13 ^ v2, 32);
        v8 += v13;
        v7 = mc_rotr64(v7 ^ v8, 24);
        v2 += v7 + input[mc_blake2b_compress__sigma[11][13]];
        v13 = mc_rotr64(v13 ^ v2, 16);
        v8 += v13;
        v7 = mc_rotr64(v7 ^ v8, 63);
        v3 += v4 + input[mc_blake2b_compress__sigma[11][14]];
        v14 = mc_rotr64(v14 ^ v3, 32);
        v9 += v14;
        v4 = mc_rotr64(v4 ^ v9, 24);
        v3 += v4 + input[mc_blake2b_compress__sigma[11][15]];
        v14 = mc_rotr64(v14 ^ v3, 16);
        v9 += v14;
        v4 = mc_rotr64(v4 ^ v9, 63);
