        u64 ech_size_offset = ech_payload_size;
        ret = encode_client_hello(tls.ctx, emitter.buf, ENCODE_CH_MODE_OUTER, is_second_flight, properties, tls.client_random, tls.client.key_share_ctx, tls.ech.client.public_name, tls.client.legacy_session_id, &tls.ech, &ech_size_offset, ptls_iovec_init(null, 0), psk.secret, psk.identity, obfuscated_ticket_age, (*(&tls.key_schedule.hashes[0] + 0)).algo.digest_size, cookie, cast(i32, tls.client.using_early_data));
