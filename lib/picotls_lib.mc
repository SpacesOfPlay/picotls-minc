void cf_chacha20_core(u8* key0, u8* key1, u8* nonce, u8* constant, u8* out) {
    u32 z0;
    u32 z1;
    u32 z2;
    u32 z3;
    u32 z4;
    u32 z5;
    u32 z6;
    u32 z7;
    u32 z8;
    u32 z9;
    u32 za;
    u32 zb;
    u32 zc;
    u32 zd;
    u32 ze;
    u32 zf;
    z0 = read32_le(constant + 0);
    u32 x0 = z0;
    z1 = read32_le(constant + 4);
    u32 x1 = z1;
    z2 = read32_le(constant + 8);
    u32 x2 = z2;
    z3 = read32_le(constant + 12);
    u32 x3 = z3;
    z4 = read32_le(key0 + 0);
    u32 x4 = z4;
    z5 = read32_le(key0 + 4);
    u32 x5 = z5;
    z6 = read32_le(key0 + 8);
    u32 x6 = z6;
    z7 = read32_le(key0 + 12);
    u32 x7 = z7;
    z8 = read32_le(key1 + 0);
    u32 x8 = z8;
    z9 = read32_le(key1 + 4);
    u32 x9 = z9;
    za = read32_le(key1 + 8);
    u32 xa = za;
    zb = read32_le(key1 + 12);
    u32 xb = zb;
    zc = read32_le(nonce + 0);
    u32 xc = zc;
    zd = read32_le(nonce + 4);
    u32 xd = zd;
    ze = read32_le(nonce + 8);
    u32 xe = ze;
    zf = read32_le(nonce + 12);
    u32 xf = zf;
    i32 i;
    for i = 0; i < 10; i++ {
        z0 += z4;
        zc = rotl32(zc ^ z0, 16);
        z8 += zc;
        z4 = rotl32(z4 ^ z8, 12);
        z0 += z4;
        zc = rotl32(zc ^ z0, 8);
        z8 += zc;
        z4 = rotl32(z4 ^ z8, 7);
                z1 += z5;
        zd = rotl32(zd ^ z1, 16);
        z9 += zd;
        z5 = rotl32(z5 ^ z9, 12);
        z1 += z5;
        zd = rotl32(zd ^ z1, 8);
        z9 += zd;
        z5 = rotl32(z5 ^ z9, 7);
                z2 += z6;
        ze = rotl32(ze ^ z2, 16);
        za += ze;
        z6 = rotl32(z6 ^ za, 12);
        z2 += z6;
        ze = rotl32(ze ^ z2, 8);
        za += ze;
        z6 = rotl32(z6 ^ za, 7);
                z3 += z7;
        zf = rotl32(zf ^ z3, 16);
        zb += zf;
        z7 = rotl32(z7 ^ zb, 12);
        z3 += z7;
        zf = rotl32(zf ^ z3, 8);
        zb += zf;
        z7 = rotl32(z7 ^ zb, 7);
                z0 += z5;
        zf = rotl32(zf ^ z0, 16);
        za += zf;
        z5 = rotl32(z5 ^ za, 12);
        z0 += z5;
        zf = rotl32(zf ^ z0, 8);
        za += zf;
        z5 = rotl32(z5 ^ za, 7);
                z1 += z6;
        zc = rotl32(zc ^ z1, 16);
        zb += zc;
        z6 = rotl32(z6 ^ zb, 12);
        z1 += z6;
        zc = rotl32(zc ^ z1, 8);
        zb += zc;
        z6 = rotl32(z6 ^ zb, 7);
                z2 += z7;
        zd = rotl32(zd ^ z2, 16);
        z8 += zd;
        z7 = rotl32(z7 ^ z8, 12);
        z2 += z7;
        zd = rotl32(zd ^ z2, 8);
        z8 += zd;
        z7 = rotl32(z7 ^ z8, 7);
                z3 += z4;
        ze = rotl32(ze ^ z3, 16);
        z9 += ze;
        z4 = rotl32(z4 ^ z9, 12);
        z3 += z4;
        ze = rotl32(ze ^ z3, 8);
        z9 += ze;
        z4 = rotl32(z4 ^ z9, 7);
            }
    x0 += z0;
    x1 += z1;
    x2 += z2;
    x3 += z3;
    x4 += z4;
    x5 += z5;
    x6 += z6;
    x7 += z7;
    x8 += z8;
    x9 += z9;
    xa += za;
    xb += zb;
    xc += zc;
    xd += zd;
    xe += ze;
    xf += zf;
    write32_le(x0, out + 0);
    write32_le(x1, out + 4);
    write32_le(x2, out + 8);
    write32_le(x3, out + 12);
    write32_le(x4, out + 16);
    write32_le(x5, out + 20);
    write32_le(x6, out + 24);
    write32_le(x7, out + 28);
    write32_le(x8, out + 32);
    write32_le(x9, out + 36);
    write32_le(xa, out + 40);
    write32_le(xb, out + 44);
    write32_le(xc, out + 48);
    write32_le(xd, out + 52);
    write32_le(xe, out + 56);
    write32_le(xf, out + 60);
}
private { u8* chacha20_tau = cast(u8*, "expand 16-byte k"); }
private { u8* chacha20_sigma = cast(u8*, "expand 32-byte k"); }
private {
void set_key(cf_chacha20_ctx* ctx, u8* key, u64 nkey) {
    switch nkey {
        case 16: {
            memcpy(ctx.key0, key, cast(u64, 16));
            memcpy(ctx.key1, key, cast(u64, 16));
            ctx.constant = chacha20_tau;
        }
        case 32: {
            memcpy(ctx.key0, key, cast(u64, 16));
            memcpy(ctx.key1, key + 16, cast(u64, 16));
            ctx.constant = chacha20_sigma;
        }
        default: {
            abort();
        }
    }
}
}
void cf_chacha20_init(cf_chacha20_ctx* ctx, u8* key, u64 nkey, u8* nonce) {
    set_key(ctx, key, nkey);
    memset(ctx.nonce, 0, cast(u64, sizeof(ctx.nonce)));
    memcpy(ctx.nonce + 8, nonce, cast(u64, 8));
    ctx.nblock = 0;
    ctx.ncounter = 8;
}
void cf_chacha20_init_custom(cf_chacha20_ctx* ctx, u8* key, u64 nkey, u8* nonce, u64 ncounter) {
    while true {
        if ncounter > 0 == 0 {
            abort();
        }
        if !(0 != 0) { break; }
    }
    set_key(ctx, key, nkey);
    memcpy(ctx.nonce, nonce, cast(u64, sizeof(ctx.nonce)));
    ctx.nblock = 0;
    ctx.ncounter = ncounter;
}
private {
void cf_chacha20_next_block(void* vctx, u8* out) {
    cf_chacha20_ctx* ctx = vctx;
    cf_chacha20_core(ctx.key0, ctx.key1, ctx.nonce, ctx.constant, out);
    incr_le(ctx.nonce, ctx.ncounter);
}
}
void cf_chacha20_cipher(cf_chacha20_ctx* ctx, u8* input, u8* output, u64 bytes) {
    cf_blockwise_xor(ctx.block, &ctx.nblock, 64, input, output, bytes, cf_chacha20_next_block, ctx);
}
