/** Returns 1 if len bytes at va equal len bytes at vb, 0 if they do not.
 *  Does not leak length of common prefix through timing. */
private {
u32 mem_eq(void* va, void* vb, u64 len) {
    u8* a = va;
    u8* b = vb;
    u8 diff = 0;
    while len-- != 0 {
        diff |= *a++ ^ *b++;
    }
    return cast(u32, !diff);
}
