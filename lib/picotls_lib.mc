}

struct __anon_struct_46 {
    u8* encoded_ch_inner;
    u8* ch_outer_aad;
    ptls_buffer_t ch_inner;
}

struct __anon_struct_47 {
    void* key;
    void* iv;
}

struct st_picotls_hmac_context_t {
    ptls_hash_context_t super;
    ptls_hash_algorithm_t* algo;
