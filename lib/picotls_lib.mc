/**
 * @brief Operations in GF(2^128).
 *
 * These implementations are constant time, but relatively slow.
 */
type cf_gf128 = u32[4];
type cf_chacha20_ctx = cf_salsa20_ctx;
type __arr_void_4 = u8*[4];
type __fnptr_0 = fn(void*, u16, ptls_iovec_t, ptls_iovec_t): i32;
/**
 * represents a sequence of octets
 */
struct st_ptls_iovec_t {
    u8* base;
    u64 len;
}

/**
 * used for storing output
 */
struct st_ptls_buffer_t {
    u8* base;
    u64 capacity;
    u64 off;
    u8 is_allocated;
    u8 align_bits;
}

/**
 * key exchange context built by ptls_key_exchange_algorithm::create.
 */
struct st_ptls_key_exchange_context_t {
    st_ptls_key_exchange_algorithm_t* algo;
    ptls_iovec_t pubkey;
    fn(st_ptls_key_exchange_context_t**, i32, ptls_iovec_t*, ptls_iovec_t): i32 on_exchange;
}

/**
 * A key exchange algorithm.
 */
struct st_ptls_key_exchange_algorithm_t {
    u16 id;
    fn(st_ptls_key_exchange_algorithm_t*, ptls_key_exchange_context_t**): i32 create;
    fn(st_ptls_key_exchange_algorithm_t*, ptls_iovec_t*, ptls_iovec_t*, ptls_iovec_t): i32 exchange;
    i64 data;
    u8* name;
}

/**
 * context of a symmetric cipher
 */
struct st_ptls_cipher_context_t {
    st_ptls_cipher_algorithm_t* algo;
    fn(st_ptls_cipher_context_t*): void do_dispose;
    fn(st_ptls_cipher_context_t*, void*): void do_init;
    fn(st_ptls_cipher_context_t*, void*, void*, u64): void do_transform;
}

/**
 * a symmetric cipher
 */
struct st_ptls_cipher_algorithm_t {
    u8* name;
    u64 key_size;
    u64 block_size;
    u64 iv_size;
    u64 context_size;
    fn(ptls_cipher_context_t*, i32, void*): i32 setup_crypto;
}

/**
 * This object specifies symmetric cipher to be calculated alongside the AEAD encryption.
 * QUIC stacks can use this object to apply QUIC header protection and AEAD encryption in one shot.
 */
struct st_ptls_aead_supplementary_encryption_t {
    ptls_cipher_context_t* ctx;
    void* input;
    u8[16] output;
}

/**
 * AEAD context.
 * AEAD implementations are allowed to stuff data at the end of the struct; see `ptls_aead_algorithm_t::setup_crypto`.
 * Ciphers for TLS over TCP MUST implement `do_encrypt`, `do_encrypt_v`, `do_decrypt`.
 * `do_encrypt_init`, `~update`, `~final` are obsolete, and therefore may not be available.
 */
struct st_ptls_aead_context_t {
    st_ptls_aead_algorithm_t* algo;
    fn(st_ptls_aead_context_t*): void dispose_crypto;
    fn(st_ptls_aead_context_t*, void*): void do_get_iv;
    fn(st_ptls_aead_context_t*, void*): void do_set_iv;
    fn(st_ptls_aead_context_t*, u64, void*, u64): void do_encrypt_init;
    fn(st_ptls_aead_context_t*, void*, void*, u64): u64 do_encrypt_update;
    fn(st_ptls_aead_context_t*, void*): u64 do_encrypt_final;
    fn(st_ptls_aead_context_t*, void*, void*, u64, u64, void*, u64, ptls_aead_supplementary_encryption_t*): void do_encrypt;
    fn(st_ptls_aead_context_t*, void*, ptls_iovec_t*, u64, u64, void*, u64): void do_encrypt_v;
    fn(st_ptls_aead_context_t*, void*, void*, u64, u64, void*, u64): u64 do_decrypt;
}

/**
 * An AEAD cipher.
 */
struct st_ptls_aead_algorithm_t {
    u8* name;
    u64 confidentiality_limit;
    u64 integrity_limit;
    ptls_cipher_algorithm_t* ctr_cipher;
    ptls_cipher_algorithm_t* ecb_cipher;
    u64 key_size;
    u64 iv_size;
    u64 tag_size;
    struct {
        u64 fixed_iv_size;
        u64 record_iv_size;
    } tls12;
    u32 non_temporal;
    u8 align_bits;
    u64 context_size;
    fn(ptls_aead_context_t*, i32, void*, void*): i32 setup_crypto;
}

/**
 * A hash context.
 */
struct st_ptls_hash_context_t {
    fn(st_ptls_hash_context_t*, void*, u64): void update;
    fn(st_ptls_hash_context_t*, void*, ptls_hash_final_mode_t): void final;
    fn(st_ptls_hash_context_t*): st_ptls_hash_context_t* clone_;
}

/**
 * A hash algorithm and its properties.
 */
struct st_ptls_hash_algorithm_t {
    u8* name;
    u64 block_size;
    u64 digest_size;
    fn(): ptls_hash_context_t* create;
    u8[64] empty_digest;
}

struct st_ptls_cipher_suite_t {
    u16 id;
    ptls_aead_algorithm_t* aead;
    ptls_hash_algorithm_t* hash;
    u8* name;
}

struct st_ptls_message_emitter_t {
    ptls_buffer_t* buf;
    st_ptls_traffic_protection_t* enc;
    u64 record_header_length;
    fn(st_ptls_message_emitter_t*): i32 begin_message;
    fn(st_ptls_message_emitter_t*): i32 commit_message;
}

/**
 * HPKE KEM
 */
struct st_ptls_hpke_kem_t {
    u16 id;
    ptls_key_exchange_algorithm_t* keyex;
    ptls_hash_algorithm_t* hash;
}

struct st_ptls_hpke_cipher_suite_id_t {
    u16 kdf;
    u16 aead;
}

struct st_ptls_hpke_cipher_suite_t {
    ptls_hpke_cipher_suite_id_t id;
    u8* name;
    ptls_hash_algorithm_t* hash;
    ptls_aead_algorithm_t* aead;
}

struct st_ptls_client_hello_psk_identity_t {
    ptls_iovec_t identity;
    u32 obfuscated_ticket_age;
    ptls_iovec_t binder;
}

/**
 * arguments passsed to the on_client_hello callback
 */
struct st_ptls_on_client_hello_parameters_t {
    ptls_iovec_t server_name;
    ptls_iovec_t raw_message;
    ptls_iovec_t cipher_suites;
    struct {
        ptls_iovec_t* list;
        u64 count;
    } negotiated_protocols;
    struct {
        u16* list;
        u64 count;
    } signature_algorithms;
    struct {
        u16* list;
        u64 count;
    } certificate_compression_algorithms;
    struct {
        u8* list;
        u64 count;
    } server_certificate_types;
    struct {
        ptls_client_hello_psk_identity_t* list;
        u64 count;
    } psk_identities;
    u32 incompatible_version;
}

/**
 * returns current time in milliseconds (ptls_get_time can be used to return the physical time)
 */
struct st_ptls_get_time_t {
    fn(st_ptls_get_time_t*): u64 cb;
}

/**
 * after receiving ClientHello, the core calls the optional callback to give a chance to the swap the context depending on the input
 * values. The callback is required to call `ptls_set_server_name` if an SNI extension needs to be sent to the client.
 */
struct st_ptls_on_client_hello_t {
    fn(st_ptls_on_client_hello_t*, ptls_t*, ptls_on_client_hello_parameters_t*): i32 cb;
}

/**
 * callback to generate the certificate message. `ptls_context::certificates` are set when the callback is set to NULL.
 */
struct st_ptls_emit_certificate_t {
    fn(st_ptls_emit_certificate_t*, ptls_t*, ptls_message_emitter_t*, ptls_key_schedule_t*, ptls_iovec_t, i32, u16*, u64): i32 cb;
}

/**
 * An object that represents an asynchronous task (e.g., RSA signature generation).
 * When `ptls_handshake` returns `PTLS_ERROR_ASYNC_OPERATION`, it has an associated task in flight. The user should obtain the
 * reference to the associated task by calling `ptls_get_async_job`, then either wait for the file descriptor obtained from
 * the `get_fd` callback to become readable, or set a completion callback via `set_completion_callback` and wait for its
 * invocation. Once notified, the user should invoke `ptls_handshake` again.
 * Async jobs typically provide support for only one of the two methods.
 */
struct st_ptls_async_job_t {
    fn(st_ptls_async_job_t*): void destroy_;
    fn(st_ptls_async_job_t*): i32 get_fd;
    fn(st_ptls_async_job_t*, fn(void*): void, void*): void set_completion_callback;
}

/**
 * When gerenating CertificateVerify, the core calls the callback to sign the handshake context using the certificate. This callback
 * supports asynchronous mode; see `ptls_openssl_sign_certificate_t` for more information.
 */
struct st_ptls_sign_certificate_t {
    fn(st_ptls_sign_certificate_t*, ptls_t*, ptls_async_job_t**, u16*, ptls_buffer_t*, ptls_iovec_t, u16*, u64): i32 cb;
}

/**
 * after receiving Certificate, the core calls the callback to verify the certificate chain and to obtain a pointer to a
 * callback that should be used for verifying CertificateVerify. If an error occurs between a successful return from this
 * callback to the invocation of the verify_sign callback, verify_sign is called with both data and sign set to an empty buffer.
 * The implementor of the callback should use that as the opportunity to free any temporary data allocated for the verify_sign
 * callback.
 * The name of the server to be verified, if any, is provided explicitly as `server_name`. When ECH is offered by the client but
 * the was rejected by the server, this value can be different from that being sent via `ptls_get_server_name`.
 */
struct st_ptls_verify_certificate_t {
    fn(st_ptls_verify_certificate_t*, ptls_t*, u8*, __fnptr_0*, void**, ptls_iovec_t*, u64): i32 cb;
    u16* algos;
}

/**
 * Encrypt-and-signs (or verify-and-decrypts) a ticket (server-only).
 * When used for encryption (i.e., is_encrypt being set), the function should return 0 if successful, or else a non-zero value.
 * When used for decryption, the function should return 0 (successful), PTLS_ERROR_REJECT_EARLY_DATA (successful, but 0-RTT is
 * forbidden), or any other value to indicate failure.
 */
struct st_ptls_encrypt_ticket_t {
    fn(st_ptls_encrypt_ticket_t*, ptls_t*, i32, ptls_buffer_t*, ptls_iovec_t): i32 cb;
}

/**
 * saves a ticket (client-only)
 */
struct st_ptls_save_ticket_t {
    fn(st_ptls_save_ticket_t*, ptls_t*, ptls_iovec_t): i32 cb;
}

/**
 * event logging (incl. secret logging)
 */
struct st_ptls_log_event_t {
    fn(st_ptls_log_event_t*, ptls_t*, u8*, u8*, ...): void cb;
}

/**
 * reference counting
 */
struct st_ptls_update_open_count_t {
    fn(st_ptls_update_open_count_t*, i64): void cb;
}

/**
 * applications that have their own record layer can set this function to derive their own traffic keys from the traffic secret.
 * The cipher-suite that is being associated to the connection can be obtained by calling the ptls_get_cipher function.
 */
struct st_ptls_update_traffic_key_t {
    fn(st_ptls_update_traffic_key_t*, ptls_t*, i32, u64, void*): i32 cb;
}

/**
 * callback for every extension detected during decoding
 */
struct st_ptls_on_extension_t {
    fn(st_ptls_on_extension_t*, ptls_t*, u8, u16, ptls_iovec_t): i32 cb;
}

/**
 *
 */
struct st_ptls_decompress_certificate_t {
    u16* supported_algorithms;
    fn(st_ptls_decompress_certificate_t*, ptls_t*, u16, ptls_iovec_t, ptls_iovec_t): i32 cb;
}

/**
 * ECH: creates the AEAD context to be used for "Open"-ing inner CH. Given `config_id`, the callback looks up the ECH config and the
 * corresponding private key, invokes `ptls_hpke_setup_base_r` with provided `cipher`, `enc`, and `info_prefix` (which will be
 * "tls ech" || 00).
 */
struct st_ptls_ech_create_opener_t {
    fn(st_ptls_ech_create_opener_t*, ptls_hpke_kem_t**, ptls_hpke_cipher_suite_t**, ptls_t*, u8, ptls_hpke_cipher_suite_id_t, ptls_iovec_t, ptls_iovec_t): ptls_aead_context_t* cb;
}

/**
 * the configuration
 */
struct st_ptls_context_t {
    fn(void*, u64): void random_bytes;
    ptls_get_time_t* get_time;
    ptls_key_exchange_algorithm_t** key_exchanges;
    ptls_cipher_suite_t** cipher_suites;
    struct {
        ptls_iovec_t* list;
        u64 count;
    } certificates;
    struct {
        ptls_iovec_t identity;
        ptls_iovec_t secret;
        ptls_hash_algorithm_t* hash;
    } pre_shared_key;
    struct {
        struct {
            ptls_hpke_cipher_suite_t** ciphers;
            ptls_hpke_kem_t** kems;
        } client;
        struct {
            ptls_ech_create_opener_t* create_opener;
            ptls_iovec_t retry_configs;
        } server;
    } ech;
    ptls_on_client_hello_t* on_client_hello;
    ptls_emit_certificate_t* emit_certificate;
    ptls_sign_certificate_t* sign_certificate;
    ptls_verify_certificate_t* verify_certificate;
    u32 ticket_lifetime;
    u32 max_early_data_size;
    u64 max_buffer_size;
    u8* hkdf_label_prefix__obsolete;
    u32 require_dhe_on_psk;
    u32 use_exporter;
    u32 send_change_cipher_spec;
    u32 require_client_authentication;
    u32 omit_end_of_early_data;
    u32 use_raw_public_keys;
    u32 server_cipher_preference;
    u32 server_cipher_chacha_priority;
    ptls_encrypt_ticket_t* encrypt_ticket;
    ptls_save_ticket_t* save_ticket;
    ptls_log_event_t* log_event;
    ptls_update_open_count_t* update_open_count;
    ptls_update_traffic_key_t* update_traffic_key;
    ptls_decompress_certificate_t* decompress_certificate;
    ptls_on_extension_t* on_extension;
    ptls_cipher_suite_t** tls12_cipher_suites;
    struct {
        u8[32] bytes;
        u32 is_set;
    } ticket_context;
    struct {
        ptls_iovec_t* list;
        u64 count;
    } client_ca_names;
    struct {
        struct {
            u8 new_session_count;
            u8 resumption_count;
        } client;
        struct {
            u8 max_count;
        } server;
    } ticket_requests;
}

struct st_ptls_raw_extension_t {
    u16 type;
    ptls_iovec_t data;
}

struct st_ptls_handshake_properties_t {
    unsafe_union {
        struct {
            struct {
                ptls_iovec_t* list;
                u64 count;
            } negotiated_protocols;
            ptls_iovec_t session_ticket;
            u64* max_early_data_size;
            ptls_early_data_acceptance_t early_data_acceptance;
            u32 negotiate_before_key_exchange;
            struct {
                ptls_iovec_t configs;
                ptls_iovec_t* retry_configs;
            } ech;
        } client;
        struct {
            struct {
                u8[64] base;
                u64 len;
            } selected_psk_binder;
            struct {
                void* key;
                ptls_iovec_t additional_data;
            } cookie;
            u32 enforce_retry;
            u32 retry_uses_cookie;
        } server;
    };
    ptls_raw_extension_t* additional_extensions;
    fn(ptls_t*, st_ptls_handshake_properties_t*, u16): i32 collect_extension;
    fn(ptls_t*, st_ptls_handshake_properties_t*, ptls_raw_extension_t*): i32 collected_extensions;
}

struct st_ptls_log_getsni_t {
    fn(void*): u8* cb;
    void* arg;
}

/**
 * Creates a lazy callback object for obtaining SNI. The object is used to delay materialization of SNI to only when it is needed.
 */
/**
 * retains a list of connections that are bound to the object
 */
struct st_ptls_log_state_t {
    u32 active_conns;
    u64 generation;
}

/**
 * represents a log point identified by name (`module:type`)
 */
struct st_ptls_log_point_t {
    u8* name;
    st_ptls_log_state_t state;
}

/**
 * represents a logging state of each connection
 */
struct st_ptls_log_conn_state_t {
    f32 random_;
    u8[16] address;
    st_ptls_log_state_t state;
}

struct st_ptls_log_t {
    u32 may_include_appdata;
    ptls_log_conn_state_t dummy_conn_state;
    u64 _generation;
}

struct st_ptls_traffic_protection_t {
    u8[64] secret;
    u64 epoch;
    ptls_aead_context_t* aead;
    u64 seq;
    u32 tls12;
    u64 tls12_enc_record_iv;
}

struct st_ptls_record_message_emitter_t {
    ptls_message_emitter_t super;
    u64 rec_start;
}

struct st_ptls_signature_algorithms_t {
    u16[64] list;
    u64 count;
}

struct st_ptls_certificate_request_t {
    ptls_iovec_t context;
    st_ptls_signature_algorithms_t signature_algorithms;
}

struct st_decoded_ech_config_t {
    u8 id;
    ptls_hpke_kem_t* kem;
    ptls_iovec_t public_key;
    ptls_hpke_cipher_suite_t* cipher;
    u8 max_name_length;
    ptls_iovec_t public_name;
    ptls_iovec_t bytes;
}

/**
 * Properties for ECH. Iff ECH is used and not rejected, `aead` is non-NULL.
 */
struct st_ptls_ech_t {
    en_ptls_ech_state_t state;
    u8 config_id;
    ptls_hpke_kem_t* kem;
    ptls_hpke_cipher_suite_t* cipher;
    ptls_aead_context_t* aead;
    u8[32] inner_client_random;
    struct {
        ptls_iovec_t enc;
        u8 max_name_length;
        u8* public_name;
        ptls_iovec_t first_ech;
    } client;
}

struct st_ptls_t {
    ptls_context_t* ctx;
    en_ptls_state_t state;
    struct {
        ptls_buffer_t rec;
        ptls_buffer_t mess;
    } recvbuf;
    ptls_key_schedule_t* key_schedule;
    struct {
        st_ptls_traffic_protection_t dec;
        st_ptls_traffic_protection_t enc;
    } traffic_protection;
    u8* server_name;
    u8* negotiated_protocol;
    ptls_key_exchange_algorithm_t* key_share;
    ptls_cipher_suite_t* cipher_suite;
    u8[32] client_random;
    struct {
        u8* early;
        u8* one_rtt;
    } exporter_master_secret;
    st_ptls_ech_t ech;
    u32 is_server;
    u32 is_psk_handshake;
    u32 send_change_cipher_spec;
    u32 needs_key_update;
    u32 key_update_send_request;
    struct {
        u32 active_conns;
        u32 generation;
    } log_sni;
    unsafe_union {
        struct {
            ptls_iovec_t legacy_session_id;
            u8[32] legacy_session_id_buf;
            ptls_key_exchange_context_t* key_share_ctx;
            u32 offered_psk;
            u32 using_early_data;
            st_ptls_certificate_request_t certificate_request;
        } client;
        struct {
            u8[64] pending_traffic_secret;
            u32 early_data_skipped_bytes;
            u8 num_tickets_to_send;
            ptls_async_job_t* async_job;
        } server;
    };
    struct {
        fn(void*, u16, ptls_iovec_t, ptls_iovec_t): i32 cb;
        void* verify_ctx;
    } certificate_verify;
    u8* pending_handshake_secret;
    void* data_ptr;
}

struct st_ptls_record_t {
    u8 type;
    u16 version;
    u64 length;
    u8* fragment;
}

struct st_ptls_client_hello_t {
    u16 legacy_version;
    u8* random_bytes;
    ptls_iovec_t legacy_session_id;
    struct {
        u8* ids;
        u64 count;
    } compression_methods;
    u16 selected_version;
    ptls_iovec_t cipher_suites;
    ptls_iovec_t negotiated_groups;
    ptls_iovec_t key_shares;
    st_ptls_signature_algorithms_t signature_algorithms;
    ptls_iovec_t server_name;
    struct {
        ptls_iovec_t[16] list;
        u64 count;
    } alpn;
    struct {
        u16[16] list;
        u64 count;
    } cert_compression_algos;
    struct {
        ptls_iovec_t all;
        ptls_iovec_t tbs;
        ptls_iovec_t ch1_hash;
        ptls_iovec_t signature;
        u32 sent_key_share;
    } cookie;
    struct {
        u8[8] list;
        u64 count;
    } server_certificate_types;
    u32 status_request;
    struct {
        u8 new_session_count;
        u8 resumption_count;
    } ticket_request;
    struct {
        u8 type;
        u8 config_id;
        ptls_hpke_cipher_suite_id_t cipher_suite;
        ptls_iovec_t enc;
        ptls_iovec_t payload;
    } ech;
    struct {
        u8* hash_end;
        struct {
            ptls_client_hello_psk_identity_t[4] list;
            u64 count;
        } identities;
        u32 ke_modes;
        u32 early_data_indication;
        u32 is_last_extension;
    } psk;
    ptls_raw_extension_t[17] unknown_extensions;
    u64 first_extension_at;
}

struct st_ptls_server_hello_t {
    u8[32] random_;
