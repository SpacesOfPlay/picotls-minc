private {
u64 build_certificate_verify_signdata(u8* data, ptls_key_schedule_t* sched, u8* context_string) {
    u64 datalen = 0;
    memset(data + datalen, 32, cast(u64, 64));
    datalen += 64;
    memcpy(data + datalen, context_string, strlen(context_string) + 1);
    datalen += strlen(context_string) + 1;
    (*(&sched.hashes[0] + 0)).ctx.final((*(&sched.hashes[0] + 0)).ctx, data + datalen, PTLS_HASH_FINAL_MODE_SNAPSHOT);
    datalen += (*(&sched.hashes[0] + 0)).algo.digest_size;
    assert(datalen <= cast(u64, 64 + sizeof("TLS 1.3, server CertificateVerify") + 64 * 2));
