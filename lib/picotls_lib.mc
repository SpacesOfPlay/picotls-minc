                        }
                    }
                    if !(0 != 0) { break; }
                }
                if src != end {
                    ret = 50;
                    return ret;
                }
                if !(0 != 0) { break; }
            }
            if !(0 != 0) { break; }
        }
        while true {
            if src != end {
                ret = 50;
                return ret;
            }
            if !(0 != 0) { break; }
        }
                if !(0 != 0) { break; }
    }
    ret = 0;
    return ret;
}
