private {
i32 client_decode_ech_config_list(ptls_context_t* ctx, st_decoded_ech_config_t* decoded, ptls_iovec_t config_list) {
    i32 ret = 0;
    defer {
        if ret != 0 {
            *decoded = st_decoded_ech_config_t{};
        }
    }
    u8* src = config_list.base;
    u8* end = src + config_list.len;
    i32 match_found = 0;
    *decoded = st_decoded_ech_config_t{};
    while true {
        while true {
            u64 _capacity = 2;
            u64 _block_size;
            if _capacity == cast(u64, -1) {
                u64 _block_size64;
                u8* _src = src;
                _block_size64 = ptls_decode_quicint(&_src, end);
                if _block_size64 == UINT64_MAX || sizeof(u64) < 8 && _block_size64 >> cast(u64, 8 * sizeof(u64)) != 0 {
                    ret = 50;
                    return ret;
                }
                src = _src;
                _block_size = _block_size64;
            } else {
                if _capacity > cast(u64, cast(i64, end - src)) {
                    ret = 50;
                    return ret;
                }
                _block_size = 0;
                while true {
                    _block_size = _block_size << 8 | *src++;
                    if !(--_capacity != 0) { break; }
                }
            }
            if _block_size > cast(u64, cast(i64, end - src)) {
                ret = 50;
                return ret;
            }
            while true {
                u8* end = src + _block_size;
                while true {
                    {
                        while true {
                            u8* config_start = src;
                            u16 version;
                            ret = ptls_decode16(&version, &src, end);
                            if ret != 0 {
                                return ret;
                            }
                            while true {
                                u64 _capacity = 2;
                                u64 _block_size;
                                if _capacity == cast(u64, -1) {
                                    u64 _block_size64;
                                    u8* _src = src;
                                    _block_size64 = ptls_decode_quicint(&_src, end);
                                    if _block_size64 == UINT64_MAX || sizeof(u64) < 8 && _block_size64 >> cast(u64, 8 * sizeof(u64)) != 0 {
                                        ret = 50;
                                        return ret;
                                    }
                                    src = _src;
                                    _block_size = _block_size64;
                                } else {
                                    if _capacity > cast(u64, cast(i64, end - src)) {
                                        ret = 50;
                                        return ret;
                                    }
                                    _block_size = 0;
                                    while true {
                                        _block_size = _block_size << 8 | *src++;
                                        if !(--_capacity != 0) { break; }
                                    }
                                }
