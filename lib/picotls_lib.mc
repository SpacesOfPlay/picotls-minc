            psk.secret = ptls_iovec_init(null, 0);
        }
    }
    if properties != null {
        if tls.client.using_early_data != 0 {
            properties.client.early_data_acceptance = PTLS_EARLY_DATA_ACCEPTANCE_UNKNOWN;
        } else {
