    u8* p = bignum;
    u8* end = p + size;
    i32 ret;
    for ; cast(i64, end - p) >= 1; ++p {
        if *p != 0 {
            break;
        }
    }
    while true {
        u8[1] __compound_lit_1 = {2};
        u8[1] __compound_lit_2 = {2};
        ret = ptls_buffer__do_pushv(buf, __compound_lit_1, cast(u64, sizeof(__compound_lit_2)));
        if ret != 0 {
            return ret;
        }
        if !(0 != 0) { break; }
    }
    while true {
        while true {
            u8[1] __compound_lit_3 = {255};
            u8[1] __compound_lit_4 = {255};
            ret = ptls_buffer__do_pushv(buf, __compound_lit_3, cast(u64, sizeof(__compound_lit_4)));
            if ret != 0 {
                return ret;
            }
            if !(0 != 0) { break; }
        }
        u64 body_start = buf.off;
        while true {
            {
                if *p >= 128 {
                    while true {
                        u8[1] __compound_lit_5 = {0};
                        u8[1] __compound_lit_6 = {0};
                        ret = ptls_buffer__do_pushv(buf, __compound_lit_5, cast(u64, sizeof(__compound_lit_6)));
                        if ret != 0 {
                            return ret;
                        }
                        if !(0 != 0) { break; }
                    }
                }
                if p != end {
                    while true {
                        ret = ptls_buffer__do_pushv(buf, p, cast(u64, cast(i64, end - p)));
                        if ret != 0 {
                            return ret;
                        }
                        if !(0 != 0) { break; }
                    }
                } else {
                    while true {
                        ret = ptls_buffer__do_pushv(buf, "", 1);
                        if ret != 0 {
                            return ret;
                        }
                        if !(0 != 0) { break; }
                    }
                }
            }
            if !(0 != 0) { break; }
        }
        u64 body_size = buf.off - body_start;
        if body_size < 128 {
            buf.base[body_start - 1] = cast(u8, body_size);
        } else {
            ret = ptls_buffer__adjust_asn1_blocksize(buf, body_size);
            if ret != 0 {
                return ret;
            }
        }
        if !(0 != 0) { break; }
    }
    ret = 0;
    return ret;
