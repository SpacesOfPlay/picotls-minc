private {
u8* byte_to_hex(u8* dst, u8 v) {
    *dst++ = "0123456789abcdef"[cast(i32, v) >> 4];
    *dst++ = "0123456789abcdef"[v & 15];
    return dst;
}
}
u8* ptls_hexdump(u8* dst, void* _src, u64 len) {
    u8* buf = dst;
    u8* src = _src;
    for u64 i = 0; i != len; ++i {
        dst = byte_to_hex(dst, src[i]);
    }
    *dst = 0;
    return buf;
}
u8* ptls_jsonescape(u8* buf, u8* unsafe_str, u64 len) {
    u8* dst = buf;
    var src = cast(u8*, unsafe_str);
    u8* end = src + len;
    for ; src != end; ++src {
        switch *src {
            case 34: {
                memcpy(dst, "\\\"", cast(u64, sizeof("\\\"") - 1));
                dst += sizeof("\\\"") - 1;
            }
            case 92: {
                memcpy(dst, "\\\\", cast(u64, sizeof("\\\\") - 1));
                dst += sizeof("\\\\") - 1;
            }
            case 47: {
                memcpy(dst, "\\\/", cast(u64, sizeof("\\\/") - 1));
                dst += sizeof("\\\/") - 1;
            }
            case 8: {
                memcpy(dst, "\\\b", cast(u64, sizeof("\\\b") - 1));
                dst += sizeof("\\\b") - 1;
            }
            case 12: {
                memcpy(dst, "\\\f", cast(u64, sizeof("\\\f") - 1));
                dst += sizeof("\\\f") - 1;
            }
            case 10: {
                memcpy(dst, "\\n", cast(u64, sizeof("\\n") - 1));
                dst += sizeof("\\n") - 1;
            }
            case 13: {
                memcpy(dst, "\\r", cast(u64, sizeof("\\r") - 1));
                dst += sizeof("\\r") - 1;
            }
            case 9: {
                memcpy(dst, "\\t", cast(u64, sizeof("\\t") - 1));
                dst += sizeof("\\t") - 1;
            }
            default: {
                if *src < 32 || *src == 127 {
                    *dst++ = 92;
                    *dst++ = 117;
                    *dst++ = 48;
                    *dst++ = 48;
                    dst = byte_to_hex(dst, *src);
                } else {
                    *dst++ = cast(u8, *src);
                }
            }
        }
    }
    *dst = 0;
    return dst;
}
void ptls_build_v4_mapped_v6_address(void* v6, void* v4) {
    memset(v6, 0, cast(u64, 10));
    memset(cast(u8*, v6) + 10, 255, cast(u64, 2));
    memcpy(cast(u8*, v6) + 12, v4, cast(u64, 4));
}
