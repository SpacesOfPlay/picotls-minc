    unsafe_union {
        ptls_iovec_t peerkey;
        struct {
            u16 selected_group;
            ptls_iovec_t cookie;
            u8* ech;
        } retry_request;
    };
}

struct __anon_struct_43 {
    ptls_hash_algorithm_t* algo;
    ptls_hash_context_t* ctx;
    ptls_hash_context_t* ctx_outer;
}

struct st_ptls_key_schedule_t {
