private {
i32 server_finish_handshake(ptls_t* tls, ptls_message_emitter_t* emitter, i32 send_cert_verify, st_ptls_signature_algorithms_t* signature_algorithms) {
    i32 ret;
    if send_cert_verify != 0 {
        ret = send_certificate_verify(tls, emitter, signature_algorithms, "TLS 1.3, server CertificateVerify");
        if ret != 0 {
            if ret == 512 + 11 {
                tls.state = PTLS_STATE_SERVER_GENERATING_CERTIFICATE_VERIFY;
            }
            return ret;
        }
    }
    ret = send_finished(tls, emitter);
    if ret != 0 {
        return ret;
    }
    assert(tls.key_schedule.generation == 2);
    ret = key_schedule_extract(tls.key_schedule, ptls_iovec_init(null, 0));
    if ret != 0 {
        return ret;
    }
    ret = setup_traffic_protection(tls, 1, "s ap traffic", 3, 0, 0);
    if ret != 0 {
        return ret;
    }
    ret = derive_secret(tls.key_schedule, tls.server.pending_traffic_secret, "c ap traffic");
    if ret != 0 {
        return ret;
    }
    ret = derive_exporter_secret(tls, 0);
    if ret != 0 {
        return ret;
    }
    if tls.pending_handshake_secret != null {
        if tls.ctx.omit_end_of_early_data != 0 {
            ret = commission_handshake_secret(tls);
            if ret != 0 {
                return ret;
            }
            tls.state = PTLS_STATE_SERVER_EXPECT_FINISHED;
        } else {
            tls.state = PTLS_STATE_SERVER_EXPECT_END_OF_EARLY_DATA;
        }
    } else if tls.ctx.require_client_authentication != 0 {
        tls.state = PTLS_STATE_SERVER_EXPECT_CERTIFICATE;
    } else {
        tls.state = PTLS_STATE_SERVER_EXPECT_FINISHED;
    }
    if tls.server.num_tickets_to_send != 0 {
        assert(tls.ctx.ticket_lifetime != 0);
        for u8 i = 0; i < tls.server.num_tickets_to_send; ++i {
            ret = send_session_ticket(tls, emitter);
            if ret != 0 {
                return ret;
            }
        }
    }
    if tls.ctx.require_client_authentication != 0 {
        ret = 512 + 2;
    } else {
        ret = 0;
    }
    return ret;
}
}
private {
i32 server_handle_end_of_early_data(ptls_t* tls, ptls_iovec_t message) {
    i32 ret;
    ret = commission_handshake_secret(tls);
    if ret != 0 {
        return ret;
    }
    ptls__key_schedule_update_hash(tls.key_schedule, message.base, message.len, 0);
    tls.state = PTLS_STATE_SERVER_EXPECT_FINISHED;
    ret = 512 + 2;
    return ret;
}
}
private {
i32 server_handle_finished(ptls_t* tls, ptls_iovec_t message) {
    i32 ret;
    ret = verify_finished(tls, message);
    if ret != 0 {
        return ret;
    }
    memcpy(tls.traffic_protection.dec.secret, tls.server.pending_traffic_secret, cast(u64, sizeof(tls.server.pending_traffic_secret)));
    ptls_clear_memory(tls.server.pending_traffic_secret, sizeof(tls.server.pending_traffic_secret));
    ret = setup_traffic_protection(tls, 0, null, 3, 0, 0);
    if ret != 0 {
        return ret;
    }
    ptls__key_schedule_update_hash(tls.key_schedule, message.base, message.len, 0);
    tls.state = PTLS_STATE_SERVER_POST_HANDSHAKE;
    return 0;
}
}
private {
i32 update_traffic_key(ptls_t* tls, i32 is_enc) {
    u8[64] secret;
    defer {
        ptls_clear_memory(secret, sizeof(secret));
    }
    st_ptls_traffic_protection_t* tp = is_enc != 0 ? &tls.traffic_protection.enc : &tls.traffic_protection.dec;
    i32 ret;
    ptls_hash_algorithm_t* hash = (*(&tls.key_schedule.hashes[0] + 0)).algo;
    ret = ptls_hkdf_expand_label(hash, secret, hash.digest_size, ptls_iovec_init(tp.secret, hash.digest_size), "traffic upd", ptls_iovec_init(null, 0), null);
    if ret != 0 {
        return ret;
    }
    memcpy(tp.secret, secret, cast(u64, sizeof(secret)));
    ret = setup_traffic_protection(tls, is_enc, null, 3, 0, 1);
    return ret;
}
}
private {
i32 handle_key_update(ptls_t* tls, ptls_message_emitter_t* emitter, ptls_iovec_t message) {
    u8* src = message.base + 4;
    u8* end = message.base + message.len;
    i32 ret;
    if cast(i64, end - src) != 1 || *src > 1 {
        return 50;
    }
    ret = update_traffic_key(tls, 0);
    if ret != 0 {
        return ret;
    }
    if *src != 0 {
        if tls.ctx.update_traffic_key != null {
            return 10;
        }
        tls.needs_key_update = 1;
    }
    return 0;
}
}
private {
i32 parse_record_header(st_ptls_record_t* rec, u8* src) {
    rec.type = src[0];
    rec.version = ntoh16(src + 1);
    rec.length = ntoh16(src + 3);
    if rec.length > cast(u64, rec.type == 23 ? 16384 + 256 : 16384) {
        return 50;
    }
    return 0;
}
}
