        b.a[i + 12] = mc_rotr64(b.a[i + 12], 32);
        b.a[i + 8] += b.a[i + 12] + (cast(u64, cast(u32, b.a[i + 8])) * cast(u64, cast(u32, b.a[i + 12])) << 1);
        b.a[i + 4] ^= b.a[i + 8];
